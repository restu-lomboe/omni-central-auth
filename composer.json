{
    "name": "developerawam/omni-central-auth",
    "description": "A plug-and-play SSO solution for Laravel — be the Identity Provider or connect as a client.",
    "keywords": ["laravel", "sso", "oauth2", "single-sign-on", "passport", "fortify", "auth"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Developer Awam",
            "email": "hello@developerawam.com",
            "homepage": "https://developerawam.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "laravel/passport": "^12.0",
        "laravel/fortify": "^1.0",
        "laravel/socialite": "^5.0",
        "livewire/livewire": "^3.0|^4.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "DeveloperAwam\\OmniCentralAuth\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DeveloperAwam\\OmniCentralAuth\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "test:unit": "vendor/bin/pest --testsuite=Unit",
        "test:feature": "vendor/bin/pest --testsuite=Feature",
        "lint": "vendor/bin/pint --test",
        "lint:fix": "vendor/bin/pint",
        "check": [
            "@lint",
            "@test"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "DeveloperAwam\\OmniCentralAuth\\OmniCentralAuthServiceProvider"
            ],
            "aliases": {
                "OmniAuth": "DeveloperAwam\\OmniCentralAuth\\Facades\\OmniAuth"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
